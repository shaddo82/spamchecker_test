# -------------------------------
# 1. 베이스 이미지 선택
# - 파이썬 3.9 버전이 설치된 리눅스 환경 사용
# - slim 이미지는 불필요한 요소를 제거해 가볍게 만든 버전
# -------------------------------
FROM python:3.9-slim
# -------------------------------
# 2. 작업 디렉토리 설정
# - 컨테이너 내부에서 /app 폴더를 기본 작업 위치로 지정
# - 이후 COPY, RUN, CMD 명령어는 모두 /app 기준으로 실행됨
# -------------------------------
WORKDIR /app
# -------------------------------
# 3. 코드 복사
# - 현재 폴더(호스트)의 app.py 파일을 컨테이너 내부 /app 폴더로 복사
# - 즉, 내가 작성한 프로그램을 이미지 안에 넣는 과정
# -------------------------------
COPY app.py .
# -------------------------------
# 4. 필요한 라이브러리 설치
# - Flask 웹 프레임워크 설치
# - RUN은 이미지 빌드 과정에서 한 번 실행됨
# -------------------------------
RUN pip install flask
# -------------------------------
# 5. 컨테이너 시작 시 실행할 명령어
# - CMD는 컨테이너가 실행될 때 수행할 기본 명령어 지정
# - 여기서는 "python app.py"를 실행 → Flask 웹 서버가 시작됨
# -------------------------------
CMD ["python", "app.py"]